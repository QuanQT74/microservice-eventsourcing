@startuml
skinparam backgroundColor white
skinparam actorStyle awesome
skinparam ArrowColor #2d6a4f
skinparam usecase {
  BackgroundColor #d8f3dc
  BorderColor #2d6a4f
}
left to right direction
title Sơ đồ Use Case BorrowingService + Saga - Theo code thực tế

actor "Người dùng" as actor

rectangle "BorrowingCommandController (/api/v1/borrowing)" {
  usecase "POST /\nTạo phiếu mượn sách" as UC_CREATE_BORROW
  usecase "POST /return\nTrả sách" as UC_RETURN
  usecase "GET /test\nKiểm tra service" as UC_TEST
}

rectangle "BorrowingSaga (điều phối tự động)" {
  usecase "Kiểm tra sách còn sẵn" as UC_CHECK_BOOK
  usecase "Cập nhật sách bận" as UC_BOOK_BUSY
  usecase "Kiểm tra nhân viên bị kỷ luật" as UC_CHECK_EMP
  usecase "Rollback sách về sẵn sàng" as UC_ROLLBACK
  usecase "Xóa phiếu mượn khi lỗi" as UC_DELETE_BORROW
}

actor --> UC_CREATE_BORROW
actor --> UC_RETURN
actor --> UC_TEST

UC_CREATE_BORROW ..> UC_CHECK_BOOK : <<include>>
UC_CREATE_BORROW ..> UC_BOOK_BUSY : <<include>>
UC_CREATE_BORROW ..> UC_CHECK_EMP : <<include>>
UC_CREATE_BORROW ..> UC_ROLLBACK : <<extend>>
UC_ROLLBACK ..> UC_DELETE_BORROW : <<include>>
UC_RETURN ..> UC_ROLLBACK : <<extend>>
@enduml