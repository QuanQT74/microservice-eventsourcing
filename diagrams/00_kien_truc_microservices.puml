@startuml
skinparam backgroundColor white
skinparam ArrowColor #2d6a4f
skinparam componentBackgroundColor #d8f3dc
skinparam componentBorderColor #2d6a4f
skinparam databaseBackgroundColor #b7e4c7
skinparam databaseBorderColor #1b4332
title Kiến Trúc Microservices - Hệ thống Quản Lý Thư Viện

actor "Nhân viên / Admin" as user

node "Docker Compose Network" {
  component "API Gateway\n:8085\n(Spring Cloud Gateway + Redis)" as gw
  component "Discovery Server\n:8761\n(Eureka)" as eureka
  component "Keycloak\n:8180\n(Identity Provider)" as kc

  component "BookService\n:9001\n(Book Command & Query)" as book
  component "EmployeeService\n:9002\n(Employee Command & Query)" as emp
  component "BorrowingService\n:9005\n(Borrowing & Saga)" as borrow
  component "UserService\n:9004\n(Keycloak Feign Client)" as usr
  component "NotificationService\n:9003\n(Kafka Consumer)" as notify

  database "Axon Server\n:8024\n(Event Store & Message Routing)" as axon
  database "MySQL\n:3307\n(read_model databases)" as mysql
  database "Redis\n:6379\n(Rate Limiting)" as redis

  queue "Kafka Broker\n:9092\n(library-events)" as kafka
}

user --> gw : Gửi Request (kèm JWT)
gw --> kc : Xác thực Token
gw --> redis : Cache/Session
gw --> book : /api/v1/book
gw --> emp : /api/v1/employees
gw --> borrow : /api/v1/borrowing
gw --> usr : /api/v1/users

book -down-> axon : Gửi Commands/Events
emp -down-> axon : Gửi Commands/Events
borrow -down-> axon : Gửi Commands/Events, điều phối Saga

book -down-> mysql : Cập nhật Read Model (Book)
emp -down-> mysql : Cập nhật Read Model (Employee)
borrow -down-> mysql : Cập nhật Read Model (Borrowing)
usr -down-> mysql : Cập nhật User DB

borrow -right-> kafka : Publish Event (KafkaTemplate)
notify -left-> kafka : Consume Event (@KafkaListener)

book -up-> eureka : Đăng ký service
emp -up-> eureka : Đăng ký service
borrow -up-> eureka : Đăng ký service
usr -up-> eureka : Đăng ký service
notify -up-> eureka : Đăng ký service
gw -up-> eureka : Khám phá service
@enduml
