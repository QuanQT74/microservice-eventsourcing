@startuml
skinparam backgroundColor white
skinparam actorStyle awesome
skinparam ArrowColor #2d6a4f
skinparam usecase {
  BackgroundColor #d8f3dc
  BorderColor #2d6a4f
}
left to right direction
title Sơ đồ Use Case UserService - Theo code thực tế

actor "Người dùng" as actor

rectangle "UserController (/api/v1/users)" {
  usecase "POST /\nTạo người dùng (admin)" as UC_USER_CREATE
  usecase "POST /register\nĐăng ký người dùng" as UC_USER_REGISTER
  usecase "GET /\nXem danh sách người dùng\n(lọc isActive)" as UC_USER_LIST
  usecase "GET /{id}\nXem chi tiết người dùng" as UC_USER_DETAIL
  usecase "GET /me/{username}\nXem thông tin bản thân" as UC_USER_ME
  usecase "PUT /{id}\nCập nhật người dùng" as UC_USER_UPDATE
  usecase "DELETE /{id}\nXóa người dùng" as UC_USER_DELETE
}

actor --> UC_USER_CREATE
actor --> UC_USER_REGISTER
actor --> UC_USER_LIST
actor --> UC_USER_DETAIL
actor --> UC_USER_ME
actor --> UC_USER_UPDATE
actor --> UC_USER_DELETE
@enduml
