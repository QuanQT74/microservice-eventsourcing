@startuml
skinparam backgroundColor white
skinparam actorStyle awesome
skinparam ArrowColor #2d6a4f
skinparam usecase {
  BackgroundColor #d8f3dc
  BorderColor #2d6a4f
}
left to right direction
title Sơ đồ Use Case Tổng Quát - Hệ thống Quản lý Thư viện

actor "Người dùng" as user
actor "Nhân viên\nThư viện" as staff
actor "Quản trị viên" as admin

rectangle "Hệ thống Quản lý Thư Viện (Event Sourcing)" {
  usecase "UC1 - Xem danh sách sách" as UC1
  usecase "UC2 - Tìm kiếm sách" as UC2
  usecase "UC3 - Xem chi tiết sách" as UC3
  usecase "UC4 - Đăng nhập hệ thống" as UC4
  usecase "UC5 - Nhận thông báo" as UC5
  usecase "UC6 - Theo dõi phiếu mượn" as UC6

  usecase "UC7 - Thêm sách mới" as UC7
  usecase "UC8 - Sửa thông tin sách" as UC8
  usecase "UC9 - Xóa sách" as UC9
  usecase "UC10 - Tạo phiếu mượn sách" as UC10
  usecase "UC11 - Trả sách" as UC11
  usecase "UC12 - Xóa phiếu mượn (hủy)" as UC12

  usecase "UC13 - Thêm nhân viên" as UC13
  usecase "UC14 - Sửa thông tin nhân viên" as UC14
  usecase "UC15 - Xóa nhân viên" as UC15
  usecase "UC16 - Cập nhật trạng thái kỷ luật nhân viên" as UC16

  usecase "UC17 - Xem Dashboard trạng thái" as UC17
  usecase "UC18 - Quản lý người dùng trên Keycloak" as UC18
}

user --> UC1
user --> UC2
user --> UC3
user --> UC4
user --> UC5
user --> UC6

staff --> UC1
staff --> UC2
staff --> UC3
staff --> UC4
staff --> UC5
staff --> UC6
staff --> UC7
staff --> UC8
staff --> UC9
staff --> UC10
staff --> UC11
staff --> UC12

admin --> UC7
admin --> UC8
admin --> UC9
admin --> UC10
admin --> UC11
admin --> UC13
admin --> UC14
admin --> UC15
admin --> UC16
admin --> UC17
admin --> UC18
@enduml