@startuml
skinparam backgroundColor white
skinparam ArrowColor #2d6a4f
skinparam activityBackgroundColor #d8f3dc
skinparam activityBorderColor #2d6a4f
skinparam ActivityDiamondBackgroundColor #b7e4c7
title Sơ đồ Luồng Mượn Sách và Saga (Chi tiết theo code)

start
:POST /api/v1/borrowing\nkèm bookId và employeeId;
:Gửi CreateBorrowingCommand;
:Tạo record Borrowing (status="BORROWED");
:Kích hoạt BorrowingSaga;
:Truy vấn GetBookDetailQuery;

if (Sách sẵn sàng (isReady == true)?) then (Có)
  :Gửi UpdateStatusBookCommand\nđể cập nhật isReady = false;
  :Nhận BookUpadateStatusEvent trong Saga;
  :Truy vấn GetDetailEmployeeQuery;

  if (Nhân viên bị kỷ luật (isDisciplined == true)?) then (Có)
    :Gửi BookRollBackStatusCommand\n(đặt lại isReady = true);
    :Gửi DeleteBorrowingCommand\nđể xóa record Borrowing;
    :Báo lỗi "Nhân Viên Kĩ Luật";
    end
  else (Không)
    :Mượn sách thành công;
    :End Saga;
    stop
  endif

else (Không)
  :Gửi DeleteBorrowingCommand\nđể xóa record Borrowing;
  :Báo lỗi "Sach da co nguoi muon";
  end
endif
@enduml
