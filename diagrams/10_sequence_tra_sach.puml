@startuml
skinparam backgroundColor white
skinparam ArrowColor #2d6a4f
skinparam sequenceArrowThickness 2
skinparam SequenceParticipantBackgroundColor #d8f3dc
skinparam SequenceParticipantBorderColor #2d6a4f
skinparam SequenceLifeLineBorderColor #2d6a4f
title Sơ đồ Trình Tự Trả Sách (Chi tiết theo code)

actor "Nhân viên" as staff
participant "API Gateway" as gw
participant "BorrowingService" as bs
participant "Axon Server" as axon
participant "BorrowingEventsHandler" as eh
participant "BorrowingSaga" as saga
participant "BookService" as book

staff -> gw: POST /api/v1/borrowing/return\n{borrowingId, bookId}
gw -> bs: Chuyển tiếp request
bs -> bs: Gửi ReturnBookCommand
bs -> axon: Publish BorrowingReturnedEvent
axon -> eh: Nhận BorrowingReturnedEvent
eh -> eh: Cập nhật DB (borrowing_db):\n- status = "RETURNED"\n- returnDate = ngày trả

axon -> saga: Nhận BorrowingReturnedEvent (Handle)
saga -> book: Gửi UpdateStatusBookCommand(isReady = true)
book -> book: Cập nhật BookAggregate\n(isReady = true)
book -> axon: Publish BookUpadateStatusEvent
saga -> saga: Kết thúc Saga (SagaLifecycle.end())

bs --> staff: Trả về JSON: {success: true, result}
@enduml
