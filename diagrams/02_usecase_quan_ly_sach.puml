@startuml
skinparam backgroundColor white
skinparam actorStyle awesome
skinparam ArrowColor #2d6a4f
skinparam usecase {
  BackgroundColor #d8f3dc
  BorderColor #2d6a4f
}
left to right direction
title Sơ đồ Use Case Quản Lý Sách - BookService

actor "Nhân viên Thư Viện" as staff
actor "Quản trị viên" as admin

rectangle "BookService (Command + Query)" {
  usecase "Xem danh sách sách\n(BookQueryController)" as UC_LIST
  usecase "Tìm kiếm sách\n(keyword, author)" as UC_SEARCH
  usecase "Xem chi tiết sách\n(GET /api/v1/books/{id})" as UC_DETAIL

  usecase "Thêm sách mới\n(CreateBookCommand)" as UC_CREATE
  usecase "Sửa thông tin sách\n(UpdateBookCommand)" as UC_UPDATE
  usecase "Xóa sách\n(DeleteBookCommand)" as UC_DELETE

  usecase "Cập nhật trạng thái sách\n(UpdateStatusBookCommand)" as UC_STATUS
  usecase "Rollback trạng thái sách\n(BookRollBackStatusCommand)" as UC_ROLLBACK
}

staff --> UC_LIST
staff --> UC_SEARCH
staff --> UC_DETAIL
staff --> UC_CREATE
staff --> UC_UPDATE
admin --> UC_DELETE

UC_CREATE ..> UC_STATUS : <<include>>
UC_ROLLBACK ..> UC_STATUS : <<extend>>
@enduml