@startuml
skinparam backgroundColor white
skinparam ArrowColor #2d6a4f
skinparam sequenceArrowThickness 2
skinparam SequenceParticipantBackgroundColor #d8f3dc
skinparam SequenceParticipantBorderColor #2d6a4f
skinparam SequenceLifeLineBorderColor #2d6a4f
title Sơ đồ Trình Tự Mượn Sách & Saga điều phối (Chi tiết theo code)

actor "Nhân viên" as staff
participant "API Gateway" as gw
participant "BorrowingService" as bs
participant "Axon Server" as axon
participant "BorrowingSaga" as saga
participant "BookService" as book
participant "EmployeeService" as emp

staff -> gw: POST /api/v1/borrowing\n{bookId, employeeId}
gw -> bs: Chuyển tiếp request
bs -> bs: Tạo UUID borrowingId
bs -> bs: Gửi CreateBorrowingCommand
bs -> axon: Publish BorrowingCreatedEvent
axon -> saga: Kích hoạt Saga (Handle)

== Giai đoạn 1: Kiểm tra Sách ==
saga -> book: Query: GetBookDetailQuery(bookId)
book --> saga: Trả về: BookResponseCommandModel (isReady)

alt Sách đã có người mượn (isReady = false)
    saga -> bs: Gửi DeleteBorrowingCommand
    bs -> axon: Publish BorrowingDeleteEvent
    axon --> saga: Kết thúc Saga
    saga --> staff: Trả về lỗi: "Sach da co nguoi muon"
else Sách sẵn sàng (isReady = true)
    saga -> book: Gửi UpdateStatusBookCommand(isReady = false)
    book -> axon: Publish BookUpadateStatusEvent
    axon -> saga: Nhận BookUpadateStatusEvent (Handle)

    == Giai đoạn 2: Kiểm tra Nhân viên ==
    saga -> emp: Query: GetDetailEmployeeQuery(employeeId)
    emp --> saga: Trả về: EmployeeResponseCommandModel (isDisciplined)

    alt Nhân viên bị kỷ luật (isDisciplined = true)
        saga -> book: Gửi BookRollBackStatusCommand (isReady = true)
        book -> axon: Publish BookUpadateStatusEvent (Rollback)
        axon -> saga: Nhận BookUpadateStatusEvent (Rollback)
        saga -> bs: Gửi DeleteBorrowingCommand
        bs -> axon: Publish BorrowingDeleteEvent
        axon --> saga: Kết thúc Saga
        saga --> staff: Trả về lỗi: "Nhân Viên Kĩ Luật"
    else Nhân viên không bị kỷ luật (isDisciplined = false)
        saga -> saga: Kết thúc Saga (SagaLifecycle.end())
        saga --> staff: Trả về JSON: {success: true, borrowingId}
    end
end
@enduml
